---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { buildDate } from "../../lib/buildDate";
import { events } from "../../data/events";

const breadcrumbs = [
  { label: "Start", href: "/" },
  { label: "Events & Messen" },
];

const dateFormatter = new Intl.DateTimeFormat("de-DE", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
const formatDate = (iso: string) => dateFormatter.format(new Date(iso));

// Sortiere chronologisch nach erstem Termin. `today` = echtes Build-Datum
// (BUILD_DATE-env oder new Date()), NICHT mehr ein hardcodeter String.
const today = buildDate();
const sorted = [...events].sort((a, b) => a.dates[0].start.localeCompare(b.dates[0].start));
const upcoming = sorted.filter((e) => e.dates[e.dates.length - 1].end >= today);
const past = sorted.filter((e) => e.dates[e.dates.length - 1].end < today);
---
<BaseLayout
  title="Events & Messen in Heidelberg - Termine, Tipps & Hotels"
  description="Aktuelle Heidelberger Events und Messen mit Hotel-Empfehlungen für jeden Termin: Schlossbeleuchtung, Schlossfestspiele, Heidelberger Herbst, Weihnachtsmarkt, Maimarkt Mannheim."
>
  <section class="relative overflow-hidden border-b border-[var(--color-lavender-ash)]" style="background: var(--color-porcelain-mist);">
    <div class="container-page pt-8 pb-14 sm:pt-16 sm:pb-20">
      <Breadcrumbs items={breadcrumbs} />
      <span class="pill-accent mt-4 inline-flex">📅 Events & Messen</span>
      <h1 class="mt-4 text-3xl sm:text-5xl font-bold tracking-tight max-w-4xl" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
        Heidelberger Events & Messen - mit Hotels für jeden Termin
      </h1>
      <p class="mt-4 text-lg sm:text-xl max-w-3xl" style="color: var(--color-shadow-graphite);">
        Schlossbeleuchtung, Schlossfestspiele, Heidelberger Herbst und der Weihnachtsmarkt - plus Mannheim-Maimarkt für Messe-Reisende. Live-Hotel-Preise für genau die Event-Wochenenden.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      {upcoming.length > 0 && (
        <>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-6" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
            Kommende Veranstaltungen
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            {upcoming.map((e) => (
              <a href={`/events/${e.slug}/`} class="card group flex flex-col p-6 hover:shadow-lg transition-all">
                <div class="text-3xl mb-3">{e.emoji}</div>
                <div class="text-[11px] font-bold uppercase tracking-widest mb-1" style="color: var(--color-accent);">
                  {e.editionLabel}
                </div>
                <h3 class="text-lg font-bold leading-snug mb-2 group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
                  {e.title}
                </h3>
                <p class="text-sm mb-3" style="color: var(--color-shadow-graphite);">
                  {e.subtitle}
                </p>
                <div class="mt-auto flex flex-col gap-1 text-xs" style="color: var(--color-slate-steel);">
                  {e.dates.map((d) => (
                    <span>📅 {formatDate(d.start)}{d.start !== d.end && ` – ${formatDate(d.end)}`}</span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </>
      )}

      {past.length > 0 && (
        <>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-6 mt-12" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
            Vergangene Veranstaltungen
          </h2>
          <p class="text-sm mb-6" style="color: var(--color-shadow-graphite);">
            Diese Termine sind vorbei - die Pages bleiben als Referenz online. Saison-Updates für das nächste Jahr folgen.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {past.map((e) => (
              <a href={`/events/${e.slug}/`} class="card group flex flex-col p-6 opacity-75 hover:opacity-100 transition-all">
                <div class="text-3xl mb-3">{e.emoji}</div>
                <div class="text-[11px] font-bold uppercase tracking-widest mb-1" style="color: var(--color-slate-steel);">
                  {e.editionLabel}
                </div>
                <h3 class="text-lg font-bold leading-snug mb-2" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
                  {e.title}
                </h3>
                <p class="text-sm" style="color: var(--color-shadow-graphite);">
                  {e.subtitle}
                </p>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>
