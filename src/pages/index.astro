---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Top10Card from "../components/Top10Card.astro";
import HueGradient from "../components/HueGradient.astro";
import AdSlot from "../components/AdSlot.astro";
import ImageCreditsList from "../components/ImageCreditsList.astro";
import { city } from "../data/city";
import { categories } from "../data/categories";
import { top10Lists, top10sByCategory } from "../data/top10s";
import { getImageCredit } from "../data/images";

const heroCredit = getImageCredit("__hero__");

const tourismus  = top10sByCategory("tourismus");
const stadtteile = top10sByCategory("stadtteile");
const leben      = top10sByCategory("leben");
const leistungen = top10sByCategory("leistungen");
const firmen     = top10sByCategory("firmen");
const blog       = top10sByCategory("blog");

const stats = {
  listen: top10Lists.length,
  kategorien: categories.length - 1, // ohne Blog
  stadtteile: stadtteile.length,
  branchen: leben.length + leistungen.length + firmen.length,
};
---
<BaseLayout title={city.brandName} description={city.description.long}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <img
      src="/images/heidelberg-hero.jpg"
      alt="Heidelberg mit Schloss und Alter Brücke"
      loading="eager"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-tr from-black/75 via-black/55 to-black/25"></div>
    {heroCredit && (
      <p class="absolute bottom-2 right-3 text-[10px] text-white/85 z-10">
        Foto:&nbsp;
        <a href={heroCredit.commonsUrl} class="underline" rel="nofollow noopener" target="_blank">{heroCredit.author}</a>
        {heroCredit.license && (
          <>
            ,&nbsp;
            {heroCredit.licenseUrl ? (
              <a href={heroCredit.licenseUrl} class="underline" rel="nofollow noopener" target="_blank">{heroCredit.license}</a>
            ) : (
              <span>{heroCredit.license}</span>
            )}
          </>
        )}
      </p>
    )}
    <div class="container-page relative pt-16 pb-20 sm:pt-24 sm:pb-32 text-white">
      <div class="max-w-3xl">
        <div class="text-xs font-bold uppercase tracking-widest mb-3" style="color: #fde68a;">Heidelbergs Bestenliste</div>
        <h1
          class="text-4xl sm:text-6xl font-bold tracking-tight text-balance text-white"
          style="font-family: var(--font-display);"
        >
          Die 10 besten Adressen für jede Branche in Heidelberg.
        </h1>
        <p class="mt-5 text-lg sm:text-xl max-w-2xl text-white/90">
          {city.description.long}
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/sehenswuerdigkeiten/" class="btn-primary">Top Sehenswürdigkeiten</a>
          <a href="/hotels/" class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-sm font-semibold transition-colors rounded-full bg-white/10 text-white ring-1 ring-white/40 hover:bg-white/20">Top Hotels</a>
          <a href="/restaurants/" class="inline-flex items-center justify-center gap-1.5 px-5 py-2.5 text-sm font-semibold rounded-full text-white hover:bg-white/10">Top Restaurants</a>
        </div>
        <dl class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl">
          {[
            { v: stats.listen,     l: "Top-10-Listen" },
            { v: stats.kategorien, l: "Kategorien" },
            { v: stats.stadtteile, l: "Stadtteile" },
            { v: stats.branchen,   l: "Branchen" },
          ].map((s) => (
            <div>
              <dt class="text-3xl font-bold text-white" style="font-family: var(--font-display);">{s.v}</dt>
              <dd class="text-xs uppercase tracking-widest mt-1 text-white/70">{s.l}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- Kategorien-Übersicht -->
  <Section eyebrow="Themen" title="Was suchst du in Heidelberg?" subtitle="Sechs Themenbereiche, jeweils mit kuratierten Top-10-Listen.">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {categories.map((c) => {
        const count = top10sByCategory(c.slug).length;
        return (
          <a href={`/thema/${c.slug}/`} class="card p-6 flex flex-col gap-3 hover:-translate-y-0.5 transition-transform">
            <div class="text-3xl">{c.icon}</div>
            <div class="text-xl font-bold" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">{c.name}</div>
            <p class="text-sm" style="color: var(--color-shadow-graphite);">{c.short}</p>
            <div class="mt-auto text-xs font-semibold" style="color: var(--color-accent);">{count} {count === 1 ? "Liste" : "Listen"} →</div>
          </a>
        );
      })}
    </div>
  </Section>

  <!-- Touristen-Top10 -->
  <Section eyebrow="Tourismus" title="Was Besucher gesehen haben sollten" subtitle="Heidelbergs Klassiker - Schloss, Hotels, Restaurants und mehr.">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {tourismus.slice(0, 6).map((l) => (
        <Top10Card href={`/${l.slug}/`} slug={l.slug} title={l.title} subtitle={l.subtitle} hue={l.hue} emoji={l.emoji} weak={l.weak} />
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/thema/tourismus/" class="btn-outline">Alle Tourismus-Listen</a>
    </div>
  </Section>

  <AdSlot slot="inContent" />

  <!-- Stadtteile -->
  <Section eyebrow="Stadtteile" title="Hotels nach Stadtteil" subtitle="In welchem Heidelberger Stadtteil willst du übernachten? Wir haben für jeden die zehn besten Adressen.">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {stadtteile.map((l) => (
        <Top10Card href={`/${l.slug}/`} slug={l.slug} title={l.district ?? l.title} subtitle={l.subtitle} hue={l.hue} emoji={l.emoji} weak={l.weak} />
      ))}
    </div>
  </Section>

  <!-- Leben in HD -->
  <Section eyebrow="Leben in Heidelberg" title="Alltag, Familie, Genuss" subtitle="Bäcker, Apotheken, Friseure, Yoga - die zehn besten Adressen für den Heidelberger Alltag." bg="soft">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {leben.slice(0, 9).map((l) => (
        <Top10Card href={`/${l.slug}/`} slug={l.slug} title={l.title} subtitle={l.subtitle} hue={l.hue} emoji={l.emoji} weak={l.weak} />
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/thema/leben/" class="btn-outline">Alle Leben-Listen</a>
    </div>
  </Section>

  <!-- Leistungen -->
  <Section eyebrow="Dienstleister" title="Profis in Heidelberg" subtitle="Anwälte, Steuerberater, Handwerk, IT - wer hilft, wenn's drauf ankommt.">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {leistungen.slice(0, 9).map((l) => (
        <Top10Card href={`/${l.slug}/`} slug={l.slug} title={l.title} subtitle={l.subtitle} hue={l.hue} emoji={l.emoji} weak={l.weak} />
      ))}
    </div>
    <div class="mt-8 text-center">
      <a href="/thema/leistungen/" class="btn-outline">Alle Leistungs-Listen</a>
    </div>
  </Section>

  <!-- Firmen + Blog kompakt -->
  <Section eyebrow="Mehr" title="Firmen & Blog" bg="soft">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[...firmen, ...blog].map((l) => (
        <Top10Card href={`/${l.slug}/`} slug={l.slug} title={l.title} subtitle={l.subtitle} hue={l.hue} emoji={l.emoji} weak={l.weak} />
      ))}
    </div>
  </Section>

  <ImageCreditsList slugs={["__hero__", ...top10Lists.map((l) => l.slug)]} />
</BaseLayout>
