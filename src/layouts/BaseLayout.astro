---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { city } from "../data/city";
import { affiliate, stay22Enabled, gygEnabled } from "../data/affiliate";
import { adsense, adsenseEnabled } from "../data/adsense";
import { analytics, gtmEnabled } from "../data/analytics";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  locale?: "de" | "en";
  hreflangs?: { de?: string; en?: string };
}

const {
  title,
  description = city.description.short,
  noindex = false,
  canonical,
  ogImage,
  locale = "de",
  hreflangs,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, city.domain).toString();
const fullTitle = title === city.brandName ? `${city.brandName} — Die besten Adressen am Neckar` : `${title} · ${city.brandName}`;
const ogLocale = locale === "en" ? "en_US" : "de_DE";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* hreflang — pro Locale ein <link>, plus x-default auf DE */}
    {hreflangs?.de && <link rel="alternate" hreflang="de" href={hreflangs.de} />}
    {hreflangs?.en && <link rel="alternate" hreflang="en" href={hreflangs.en} />}
    {hreflangs?.de && <link rel="alternate" hreflang="x-default" href={hreflangs.de} />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    {locale === "en" && <meta property="og:locale:alternate" content="de_DE" />}
    {locale === "de" && hreflangs?.en && <meta property="og:locale:alternate" content="en_US" />}
    {ogImage && <meta property="og:image" content={ogImage} />}

    
    {stay22Enabled && (
      <script
        async
        src={`https://snippet.stay22.com/allez/script?lmaid=${affiliate.stay22.lmaId}`}
      ></script>
    )}

    {gygEnabled && (
      <script
        async
        defer
        src="https://widget.getyourguide.com/dist/pa.umd.production.min.js"
        data-gyg-partner-id={affiliate.getYourGuide.partnerId}
      ></script>
    )}

    {adsenseEnabled && !noindex && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.publisherId}`}
        crossorigin="anonymous"
      ></script>
    )}

    {gtmEnabled && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${analytics.gtmId}');`} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    {gtmEnabled && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${analytics.gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}
    <Header />
    <main class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />
  </body>
</html>
