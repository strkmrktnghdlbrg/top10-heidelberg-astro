---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { city } from "../data/city";
import { affiliate, stay22Enabled, gygEnabled } from "../data/affiliate";
import { adsense, adsenseEnabled } from "../data/adsense";
import { analytics, gtmEnabled } from "../data/analytics";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  ogImage?: string;
  locale?: "de" | "en";
  hreflangs?: { de?: string; en?: string };
}

const {
  title,
  description = city.description.short,
  noindex = false,
  canonical,
  ogImage,
  locale = "de",
  hreflangs,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, city.domain).toString();
const fullTitle = title === city.brandName ? `${city.brandName} - Die besten Adressen am Neckar` : `${title} · ${city.brandName}`;
const ogLocale = locale === "en" ? "en_US" : "de_DE";

// Social-Preview-Bild: übergebenes ogImage (relativ oder absolut) auf eine
// absolute URL auflösen; sonst site-weites Default-Hero. So hat JEDE Seite
// ein og:image + twitter:image (vorher nur eine einzige Seite site-weit).
const ogImageUrl = new URL(ogImage ?? "/images/heidelberg-hero.jpg", city.domain).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* hreflang — pro Locale ein <link>, plus x-default auf DE */}
    {hreflangs?.de && <link rel="alternate" hreflang="de" href={hreflangs.de} />}
    {hreflangs?.en && <link rel="alternate" hreflang="en" href={hreflangs.en} />}
    {hreflangs?.de && <link rel="alternate" hreflang="x-default" href={hreflangs.de} />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    {locale === "en" && <meta property="og:locale:alternate" content="de_DE" />}
    {locale === "de" && hreflangs?.en && <meta property="og:locale:alternate" content="en_US" />}
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />


    {/* Nicht notwendige Drittanbieter-Skripte werden bewusst INERT gerendert
        (type="text/plain") und erst nach Einwilligung im Cookie-Banner von
        CookieConsent.astro aktiviert. So werden vor dem Opt-in keine
        Drittanbieter-Cookies gesetzt und keine Daten übertragen (§ 25 TTDSG). */}
    {stay22Enabled && (
      <script
        type="text/plain"
        data-cc="all"
        async
        data-cc-src={`https://snippet.stay22.com/allez/script?lmaid=${affiliate.stay22.lmaId}`}
      ></script>
    )}

    {gygEnabled && (
      <script
        type="text/plain"
        data-cc="all"
        async
        defer
        data-cc-src="https://widget.getyourguide.com/dist/pa.umd.production.min.js"
        data-gyg-partner-id={affiliate.getYourGuide.partnerId}
      ></script>
    )}

    {adsenseEnabled && !noindex && (
      <script
        type="text/plain"
        data-cc="all"
        async
        crossorigin="anonymous"
        data-cc-src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsense.publisherId}`}
      ></script>
    )}

    {gtmEnabled && (
      <script type="text/plain" data-cc="all" set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${analytics.gtmId}');`} />
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    {/* Kein GTM-<noscript>-iframe: ohne JS kann keine Einwilligung eingeholt
        werden, daher darf ohne Opt-in auch kein Tag Manager geladen werden. */}
    <Header />
    <main class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
