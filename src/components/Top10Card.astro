---
import ContentImage from "./ContentImage.astro";

interface Props {
  href: string;
  slug?: string;       // verwendet, um Bild aus public/images/ aufzulösen
  title: string;
  subtitle?: string;
  hue: 1 | 2 | 3 | 4 | 5;
  emoji?: string;
  badge?: string;
  weak?: boolean;
}
const { href, slug, title, subtitle, hue, emoji, badge, weak } = Astro.props;
---
<a href={href} class="card group flex flex-col overflow-hidden">
  <div class="relative aspect-[4/3]">
    <ContentImage slug={slug ?? "__none__"} alt={title} hue={hue} emoji={emoji} class="absolute inset-0" showCredit variant="card" />
    {badge && (
      <span class="absolute top-3 left-3 pill bg-white">{badge}</span>
    )}
    {weak && (
      <span class="absolute top-3 right-3 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-white/90 text-amber-700">
        Entwurf
      </span>
    )}
  </div>
  <div class="p-5 flex-1 flex flex-col">
    <h3 class="text-lg font-bold leading-snug" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
      {title}
    </h3>
    {subtitle && (
      <p class="mt-1.5 text-sm" style="color: var(--color-shadow-graphite);">{subtitle}</p>
    )}
    <span class="mt-3 text-xs font-semibold inline-flex items-center gap-1" style="color: var(--color-accent);">
      Liste lesen
      <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </span>
  </div>
</a>
