---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "./Section.astro";
import HueGradient from "./HueGradient.astro";
import RankBadge from "./RankBadge.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import Top10Card from "./Top10Card.astro";
import AdSlot from "./AdSlot.astro";
import Stay22Map from "./Stay22Map.astro";
import GetYourGuideWidget from "./GetYourGuideWidget.astro";
import ContentImage from "./ContentImage.astro";
import ImageCreditsList from "./ImageCreditsList.astro";
import Stay22TopHotels from "./Stay22TopHotels.astro";
import type { Top10List } from "../data/top10s";
import { top10sByCategory, top10Lists } from "../data/top10s";
import { categories, getCategory } from "../data/categories";
import { getImage, getImageCredit } from "../data/images";
import { getDistrictGeo } from "../data/districts";
import { city } from "../data/city";

import { hasTranslation } from "../data/i18n";

interface Props {
  list: Top10List;
  locale?: "de" | "en";
}
const { list, locale = "de" } = Astro.props;
const cat = getCategory(list.category)!;
const sibling = top10sByCategory(list.category).filter((l) => l.slug !== list.slug).slice(0, 6);
const otherCats = categories.filter((c) => c.slug !== list.category && c.slug !== "blog");

const description =
  list.metaDescription ||
  list.subtitle ||
  list.intro.slice(0, 160);

const isEn = locale === "en";
const pathPrefix = isEn ? "/en" : "";
const startLabel = isEn ? "Home" : "Start";
// EN-Label für die Kategorie (nur Tourismus-Listen haben EN-Seiten, die
// übrigen Keys sind Fallbacks fürs saubere Chrome).
const CAT_LABEL_EN: Record<string, string> = {
  tourismus: "Attractions & Tourism",
  stadtteile: "Districts",
  leben: "City Life",
  leistungen: "Services",
  firmen: "Business",
  blog: "Blog",
};
const catLabel = isEn ? (CAT_LABEL_EN[cat.slug] ?? cat.name) : cat.name;

const breadcrumbs = isEn
  ? [
      { label: "Home", href: "/en/" },
      { label: list.title },
    ]
  : [
      { label: "Start", href: "/" },
      { label: cat.name, href: `/thema/${cat.slug}/` },
      { label: list.title },
    ];

// hreflang: wenn EN-Übersetzung existiert, hreflang-Paar setzen
const hasEn = hasTranslation(list.slug, "en");
const hreflangs = hasEn
  ? {
      de: `${city.domain}/${list.slug}/`,
      en: `${city.domain}/en/${list.slug}/`,
    }
  : undefined;

// Sibling-Links: auf EN-Seiten zu /en/<slug>/ verlinken, sofern für den
// Sibling eine EN-Übersetzung existiert; sonst auf die DE-Seite.
const listHref = (s: { slug: string }) =>
  isEn && hasTranslation(s.slug, "en") ? `/en/${s.slug}/` : `/${s.slug}/`;

const showStay22 = !!list.affiliate?.stay22;
const showGyg = !!list.affiliate?.getYourGuide;
const heroImage = getImage(list.slug);
const heroCredit = heroImage ? getImageCredit(list.slug) : null;
const siblingSlugs = sibling.map((s) => s.slug);

// Stay22 — Stadtteil-Map-Center + Live-Hotel-Block
const districtGeo = list.district ? getDistrictGeo(list.district) : undefined;
const mapLat = districtGeo?.coordinates[0] ?? city.coordinates[0];
const mapLng = districtGeo?.coordinates[1] ?? city.coordinates[1];
const mapZoom = districtGeo ? 15 : 13;

// JSON-LD ItemList — mit kategoriespezifischem item-Schema-Type.
// Google nutzt die spezifischeren Typen (TouristAttraction, Hotel,
// Restaurant, LocalBusiness) für Rich Results in Search.
function schemaTypeForList(slug: string, category: string): string {
  if (slug.endsWith("-hotels") || slug === "hotels") return "Hotel";
  if (slug === "restaurants") return "Restaurant";
  if (slug === "cafes") return "CafeOrCoffeeShop";
  if (slug === "bars-und-kneipen") return "BarOrPub";
  if (slug === "baeckereien") return "Bakery";
  if (slug === "apotheken") return "Pharmacy";
  if (["tierarzt", "tieraerzte"].includes(slug)) return "VeterinaryCare";
  if (slug === "wellness-spa") return "DaySpa";
  if (slug === "fitnessstudios") return "ExerciseGym";
  if (slug === "yogastudios-entspannung-betaetigung") return "ExerciseGym";
  if (slug === "kunstgalerien") return "ArtGallery";
  if (slug === "musikschulen") return "MusicSchool";
  if (slug === "buchlaeden") return "BookStore";
  if (slug === "blumenladen") return "Florist";
  if (slug === "weinladen") return "WineStore";
  if (slug === "bio-laden") return "GroceryStore";
  if (slug === "fahrradladen") return "BikeStore";
  if (["rechtsanwalte", "steuerberater", "immobilienmakler", "it-dienstleister-computerreparatur", "hochzeitsplaner"].includes(slug)) return "ProfessionalService";
  if (["handwerker", "umzugsunternehmen", "gartengestaltung-heidelberg", "auto-service-wieblingen", "autowerkstaetten"].includes(slug)) return "LocalBusiness";
  if (["online-werbeagenturen", "coworking-spaces"].includes(slug)) return "Organization";
  if (category === "tourismus") return "TouristAttraction";
  return "LocalBusiness";
}

const itemSchemaType = schemaTypeForList(list.slug, list.category);
const cityName = city.name;
const countryCode = "DE";

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: list.title,
  description,
  numberOfItems: list.items.length,
  itemListElement: list.items.map((it) => {
    const item: any = {
      "@type": itemSchemaType,
      name: it.name,
      description: it.description,
    };
    if (it.address) {
      item.address = {
        "@type": "PostalAddress",
        streetAddress: it.address,
        addressLocality: list.district ?? cityName,
        addressCountry: countryCode,
      };
    } else {
      item.address = {
        "@type": "PostalAddress",
        addressLocality: list.district ?? cityName,
        addressCountry: countryCode,
      };
    }
    if (it.websiteUrl) item.url = it.websiteUrl;
    return {
      "@type": "ListItem",
      position: it.rank,
      item,
    };
  }),
};

// Zusätzliches BreadcrumbList-Schema
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Start", item: city.domain + "/" },
    { "@type": "ListItem", position: 2, name: cat.name, item: `${city.domain}/thema/${cat.slug}/` },
    { "@type": "ListItem", position: 3, name: list.title },
  ],
};

// FAQPage-Schema — nur wenn die Liste einen FAQ-Block hat (ausgebaute Money-Pages).
const faqJsonLd = list.faq && list.faq.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: list.faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    }
  : null;
---

<BaseLayout title={list.title} description={description} locale={locale} hreflangs={hreflangs}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-[var(--color-lavender-ash)]" style="background: var(--color-porcelain-mist);">
    {heroImage ? (
      <>
        <img
          src={heroImage}
          alt={list.title}
          loading="eager"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/45 to-black/15"></div>
      </>
    ) : (
      <HueGradient hue={list.hue} class="absolute inset-0 opacity-30 pointer-events-none" />
    )}
    <div class={`container-page relative pt-8 pb-14 sm:pt-16 sm:pb-24 ${heroImage ? "text-white" : ""}`}>
      <Breadcrumbs items={breadcrumbs} />
      <div class="mt-4 flex flex-wrap items-center gap-2">
        <span class="pill-accent">{cat.icon} {catLabel}</span>
        {list.district && <span class="pill">{list.district}</span>}
        {list.weak && <span class="pill" style="color:#92400e;background:#fef3c7;border-color:#fde68a;">{isEn ? "Draft list" : "Entwurfs-Liste"}</span>}
      </div>
      <h1
        class="mt-4 text-3xl sm:text-5xl font-bold tracking-tight text-balance max-w-4xl"
        style={`font-family: var(--font-display); color: ${heroImage ? "#fff" : "var(--color-inkwell-purple)"};`}
      >
        {list.title}
      </h1>
      {list.subtitle && (
        <p class="mt-4 text-lg sm:text-xl max-w-2xl" style={`color: ${heroImage ? "rgba(255,255,255,0.92)" : "var(--color-shadow-graphite)"};`}>
          {list.subtitle}
        </p>
      )}
      {heroImage && heroCredit && (
        <p class="absolute bottom-2 right-3 text-[10px] text-white/85">
          {isEn ? "Photo:" : "Foto:"}&nbsp;
          <a href={heroCredit.commonsUrl} class="underline" rel="nofollow noopener" target="_blank">{heroCredit.author}</a>
          {heroCredit.license && (
            <>
              ,&nbsp;
              {heroCredit.licenseUrl ? (
                <a href={heroCredit.licenseUrl} class="underline" rel="nofollow noopener" target="_blank">{heroCredit.license}</a>
              ) : (
                <span>{heroCredit.license}</span>
              )}
            </>
          )}
        </p>
      )}
    </div>
  </section>

  <!-- Intro + Liste -->
  <section class="section">
    <div class="container-page grid lg:grid-cols-[1fr_320px] gap-10">
      <div class="min-w-0">
        {list.intro && (
          <p class="text-base sm:text-lg leading-relaxed mb-10" style="color: var(--color-inkwell-purple);">
            {list.intro}
          </p>
        )}

        {/* GYG-Legacy-Block: nur wenn affiliate.getYourGuide=true UND KEIN list.gyg-Override gesetzt ist.
            Sonst rendert der Widget unten an der konfigurierten placement-Position. */}
        {showGyg && !list.gyg && (
          <div class="mb-10">
            <GetYourGuideWidget query={`Heidelberg ${list.title.replace(/^Top 10\s*/, "")}`} locale={locale} />
          </div>
        )}

        {list.items.length === 0 ? (
          <div class="card p-8 text-center" style="border-style: dashed;">
            <div class="text-4xl mb-3">🛠️</div>
            <h3 class="text-lg font-bold mb-1" style="font-family: var(--font-display);">{isEn ? "List in progress" : "Liste in Bearbeitung"}</h3>
            <p class="text-sm" style="color: var(--color-shadow-graphite);">
              {isEn
                ? "This Top 10 is currently being revised by our editors. The previous content listed too few concrete places."
                : "Diese Top 10 wird gerade redaktionell überarbeitet. Die alten Inhalte enthielten zu wenig konkrete Anbieter."}
            </p>
          </div>
        ) : (
          <ol class="space-y-6">
            {list.items.map((it, idx) => (
              <li class="card p-5 sm:p-6 flex gap-4 sm:gap-6">
                <RankBadge rank={it.rank} />
                <div class="min-w-0 flex-1">
                  <h2
                    class="text-xl sm:text-2xl font-bold tracking-tight leading-snug"
                    style="font-family: var(--font-display); color: var(--color-inkwell-purple);"
                  >
                    {it.name}
                  </h2>
                  {it.description && (
                    <p class="mt-2 text-base leading-relaxed" style="color: var(--color-shadow-graphite);">
                      {it.description}
                    </p>
                  )}
                  {(it.address || it.websiteUrl) && (
                    <div class="mt-3 flex flex-wrap gap-3 text-sm">
                      {it.address && <span style="color: var(--color-slate-steel);">📍 {it.address}</span>}
                      {it.websiteUrl && (
                        <a
                          href={it.websiteUrl}
                          class="link-accent"
                          rel={it.dofollow ? "noopener" : "nofollow noopener"}
                          target="_blank"
                        >
                          {it.anchorText ?? (isEn ? "Website ↗" : "Webseite ↗")}
                        </a>
                      )}
                    </div>
                  )}
                </div>
              </li>
            ))}
          </ol>
        )}

        {/* In-Content-Ad nach Top 5 (sofern Liste lang genug) */}
        {list.items.length >= 5 && <AdSlot slot="inContent" />}

        {/* GYG-Widget bei placement=after-top10-list (auch Fallback für before-faq, da Top10 keine FAQ hat) */}
        {showGyg && list.gyg && (list.gyg.placement === "after-top10-list" || list.gyg.placement === "before-faq") && (
          <GetYourGuideWidget
            variant={list.gyg.variant}
            query={list.gyg.query}
            numberOfItems={list.gyg.numberOfItems}
            headline={list.gyg.headline}
            lead={list.gyg.lead}
            locale={locale}
          />
        )}

        {showStay22 && (
          <>
            <Stay22TopHotels
              locale={locale}
              lat={districtGeo ? mapLat : undefined}
              lng={districtGeo ? mapLng : undefined}
              radius={districtGeo ? 2500 : undefined}
              address={districtGeo ? undefined : `${city.name}, Germany`}
              title={isEn
                ? (districtGeo
                    ? `Live hotels in ${list.district}`
                    : `Top-rated hotels in ${city.name} right now`)
                : (districtGeo
                    ? `Live-Hotels in ${list.district}`
                    : `Aktuell bestbewertete Hotels in ${city.name}`)}
              lead={isEn
                ? "Live prices and availability via Stay22. Updated at the last build."
                : "Live-Preise und Verfügbarkeit über Stay22. Aktualisiert beim letzten Build."}
              limit={8}
            />
            <Stay22Map
              locale={locale}
              lat={mapLat}
              lng={mapLng}
              zoom={mapZoom}
              title={isEn ? "Compare availability & prices" : "Verfügbarkeit & Preise vergleichen"}
              lead={isEn
                ? (districtGeo
                    ? `All hotels in and around ${list.district} with live prices. Click a marker for details.`
                    : "Hotel map with live prices and availability. Click a marker for details.")
                : (districtGeo
                    ? `Alle Hotels in und um ${list.district} mit Live-Preisen. Klick auf einen Marker zeigt Details.`
                    : "Hotel-Karte mit Live-Preisen und Verfügbarkeit. Klick auf einen Marker zeigt Details.")}
            />
          </>
        )}

        {/* GYG-Widget bei placement=after-hotels — direkt nach dem Stay22-Block */}
        {showGyg && list.gyg && list.gyg.placement === "after-hotels" && (
          <GetYourGuideWidget
            variant={list.gyg.variant}
            query={list.gyg.query}
            numberOfItems={list.gyg.numberOfItems}
            headline={list.gyg.headline}
            lead={list.gyg.lead}
            locale={locale}
          />
        )}

        {/* Langform-Ratgeber (z.B. Stadtteil-Guide) — nur bei ausgebauten Seiten */}
        {list.body && list.body.length > 0 && (
          <div class="mt-12 space-y-8 max-w-3xl">
            {list.body.map((sec) => (
              <div>
                <h2
                  class="text-2xl sm:text-3xl font-bold tracking-tight mb-4"
                  style="font-family: var(--font-display); color: var(--color-inkwell-purple);"
                >
                  {sec.heading}
                </h2>
                <div class="space-y-4">
                  {sec.paragraphs.map((p) => (
                    <p class="text-base leading-relaxed" style="color: var(--color-shadow-graphite);">{p}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}

        {/* FAQ-Block + FAQPage-Schema (Markup wie EventPage.astro) */}
        {list.faq && list.faq.length > 0 && (
          <div class="mt-12 max-w-3xl">
            <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-6" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
              {isEn ? "Frequently asked questions" : "Häufige Fragen"}
            </h2>
            <div class="space-y-4">
              {list.faq.map((f) => (
                <details class="card p-5 group">
                  <summary class="cursor-pointer font-bold text-base sm:text-lg list-none flex justify-between items-start gap-4" style="color: var(--color-inkwell-purple);">
                    <span>{f.q}</span>
                    <span class="text-xl transition-transform group-open:rotate-45" aria-hidden="true">+</span>
                  </summary>
                  <p class="mt-3 text-base leading-relaxed" style="color: var(--color-shadow-graphite);">
                    {f.a}
                  </p>
                </details>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 min-w-0">
        <AdSlot slot="sidebar" minHeight={300} />

        <div class="card p-5">
          <div class="eyebrow mb-3">{isEn ? `More from ${catLabel}` : `Mehr aus ${cat.name}`}</div>
          <ul class="space-y-2 text-sm">
            {sibling.map((s) => (
              <li>
                <a href={listHref(s)} class="link-accent font-medium">{s.title}</a>
              </li>
            ))}
          </ul>
        </div>

        <div class="card p-5">
          <div class="eyebrow mb-3">{isEn ? "Other topics" : "Andere Themen"}</div>
          <ul class="space-y-1 text-sm">
            {otherCats.map((c) => (
              <li>
                <a href={`/thema/${c.slug}/`} class="link-accent">{c.icon} {c.name}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <!-- Weitere Listen aus Kategorie -->
  {sibling.length > 0 && (
    <Section eyebrow={catLabel} title={isEn ? `More Top 10 lists from ${catLabel}` : `Weitere Top-10-Listen aus ${cat.name}`}>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sibling.map((s) => (
          <Top10Card href={listHref(s)} slug={s.slug} title={s.title} subtitle={s.subtitle} hue={s.hue} emoji={s.emoji} weak={s.weak} />
        ))}
      </div>
    </Section>
  )}

  <ImageCreditsList slugs={[list.slug, ...siblingSlugs]} />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}
</BaseLayout>
