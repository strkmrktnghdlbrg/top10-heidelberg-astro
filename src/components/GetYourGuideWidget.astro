---
/**
 * GetYourGuide Touren-Widget.
 * ---------------------------
 * Rendert ein konfiguriertes GYG-Widget mit Heidelberg-Location-ID
 * (49069). Zwei Varianten:
 *  - "search-query" (default): nutzt data-gyg-q="<query>" für thematisch
 *    fokussierte Tour-Listen ("Heidelberg Castle Tour" etc.)
 *  - "auto-city": KEIN data-gyg-q, nur location-id — zeigt GYGs eigenen
 *    Default-Feed für Heidelberg (breit + ranking-getrieben)
 *
 * Optional headline + lead direkt über dem Widget — falls die einbettende
 * Page nichts eigenes drumherum baut.
 *
 * Render-Verhalten:
 *  - gygEnabled=false → leiser Platzhalter (Dev/Staging)
 *  - gygEnabled=true  → echte Widget-DIV; das pa.umd.production.min.js
 *    in BaseLayout greift sie sich automatisch via data-attribute scan
 */
import { affiliate, gygEnabled } from "../data/affiliate";

interface Props {
  variant?: "search-query" | "auto-city";
  query?: string;
  locationId?: string;
  numberOfItems?: number;
  headline?: string;
  lead?: string;
}

const {
  variant = "search-query",
  query = "Heidelberg",
  locationId = "49069",
  numberOfItems = 6,
  headline,
  lead,
} = Astro.props;
---
{gygEnabled ? (
  <section class="my-12 gyg-widget-host">
    {(headline || lead) && (
      <div class="mb-5 max-w-3xl">
        <p class="eyebrow mb-2">Touren & Erlebnisse</p>
        {headline && (
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight mb-2" style="font-family: var(--font-display); color: var(--color-inkwell-purple);">
            {headline}
          </h2>
        )}
        {lead && (
          <p class="text-base leading-relaxed" style="color: var(--color-shadow-graphite);">
            {lead}
          </p>
        )}
      </div>
    )}

    <div
      data-gyg-href="https://widget.getyourguide.com/default/activities.frame"
      data-gyg-locale-code="de-DE"
      data-gyg-widget="activities"
      data-gyg-number-of-items={numberOfItems}
      data-gyg-partner-id={affiliate.getYourGuide.partnerId}
      data-gyg-location-id={locationId}
      {...(variant === "search-query" ? { "data-gyg-q": query } : {})}
      style="min-height: 380px;"
    ></div>

    <p class="mt-3 text-[11px] leading-relaxed" style="color: var(--color-slate-steel);">
      * Tickets, Touren & Erlebnisse über Partner GetYourGuide (Affiliate-Link). Preise und Verfügbarkeit live aus dem GYG-Marktplatz.
    </p>
  </section>
) : (
  <div
    class="flex items-center justify-center text-sm text-center px-6 py-12 rounded-2xl"
    style="background: var(--color-porcelain-mist); color: var(--color-slate-steel);"
  >
    Touren & Tickets-Widget (GetYourGuide) — aktiv, sobald die Partner-ID gesetzt ist.
  </div>
)}
