---
/**
 * Cookie-Consent-Banner (GDPR / TTDSG-konform, vanilla JS).
 *
 * Funktioniert so:
 *  1. Beim ersten Page-Load erscheint der Banner unten.
 *  2. Bis zur Entscheidung werden KEINE Marketing-/Affiliate-Scripts
 *     geladen — Stay22, GetYourGuide, AdSense, GTM sind im
 *     BaseLayout als `type="text/plain" data-consent-marketing` gerendert.
 *  3. Klick auf "Alle akzeptieren": localStorage.consent = "all" +
 *     JS aktiviert die Scripts (set type=text/javascript) und
 *     re-inserted sie, damit der Browser sie ausführt.
 *  4. Klick auf "Nur notwendige": localStorage.consent = "essential"
 *     → Marketing-Scripts bleiben deaktiviert, Banner verschwindet.
 *  5. Footer-Link "Cookie-Einstellungen" öffnet den Banner erneut.
 *
 * Speichert KEINE eigenen Tracking-Cookies — nur einen localStorage-
 * Eintrag mit der User-Wahl. Damit ist der Banner selbst
 * cookie-frei und immer DSGVO-konform.
 */
---
<div
  id="cookie-banner"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookie-banner-title"
  hidden
  style="position: fixed; left: 1rem; right: 1rem; bottom: 1rem; z-index: 80; max-width: 720px; margin-inline: auto; background: #fff; border: 1px solid var(--color-lavender-ash); border-radius: var(--radius-card); box-shadow: 0 12px 32px rgba(0,0,0,0.18); padding: 1.25rem 1.5rem;"
>
  <h2 id="cookie-banner-title" style="font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--color-inkwell-purple); margin-bottom: 0.5rem;">
    Cookies & Affiliate-Widgets
  </h2>
  <p style="font-size: 0.875rem; line-height: 1.55; color: var(--color-shadow-graphite); margin-bottom: 1rem;">
    Wir laden auf Wunsch eingebettete Inhalte unserer Partner Stay22 (Hotel-Karten und -Preise), GetYourGuide
    (Touren-Widgets) und Google AdSense (Anzeigen). Diese Anbieter setzen eigene Cookies und können Daten in
    Drittländer übertragen. Notwendig sind sie für den Seitenbetrieb nicht — du entscheidest, ob sie geladen werden.
    Details in der <a href="/datenschutz/" style="color: var(--color-accent); text-decoration: underline;">Datenschutzerklärung</a>.
  </p>
  <div style="display: flex; flex-wrap: wrap; gap: 0.625rem;">
    <button
      type="button"
      id="cookie-accept-all"
      style="flex: 1 1 auto; min-width: 160px; padding: 0.75rem 1.25rem; border-radius: 12px; border: none; background: var(--color-accent); color: #fff; font-weight: 700; font-size: 0.875rem; cursor: pointer;"
    >
      Alle akzeptieren
    </button>
    <button
      type="button"
      id="cookie-essential-only"
      style="flex: 1 1 auto; min-width: 160px; padding: 0.75rem 1.25rem; border-radius: 12px; border: 1px solid var(--color-lavender-ash); background: #fff; color: var(--color-inkwell-purple); font-weight: 600; font-size: 0.875rem; cursor: pointer;"
    >
      Nur notwendige
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "top10hd-consent";
    var banner = document.getElementById("cookie-banner");
    var btnAll = document.getElementById("cookie-accept-all");
    var btnEss = document.getElementById("cookie-essential-only");
    if (!banner) return;

    function getConsent() {
      try { return localStorage.getItem(KEY); } catch (_) { return null; }
    }
    function setConsent(value) {
      try { localStorage.setItem(KEY, value); } catch (_) {}
    }

    function activateMarketing() {
      // Jeden mit data-consent-marketing markierten Script-Tag in ein echtes Script-Element kopieren.
      // Browser führen Scripts mit type="text/plain" nicht aus — wir setzen type weg/auf "text/javascript"
      // und re-inserten als neuen Knoten, damit das Script ausgeführt wird.
      var pending = document.querySelectorAll('script[data-consent-marketing][type="text/plain"]');
      pending.forEach(function (orig) {
        var s = document.createElement("script");
        // Alle Attribute übernehmen
        for (var i = 0; i < orig.attributes.length; i++) {
          var a = orig.attributes[i];
          if (a.name === "type") continue;
          s.setAttribute(a.name, a.value);
        }
        if (orig.src) s.src = orig.src;
        else s.text = orig.text;
        orig.parentNode.replaceChild(s, orig);
      });
    }

    function showBanner() { banner.removeAttribute("hidden"); }
    function hideBanner() { banner.setAttribute("hidden", ""); }

    btnAll.addEventListener("click", function () {
      setConsent("all");
      activateMarketing();
      hideBanner();
    });
    btnEss.addEventListener("click", function () {
      setConsent("essential");
      hideBanner();
    });

    // Footer-Link "Cookie-Einstellungen" kann den Banner re-öffnen
    document.querySelectorAll('[data-cookie-settings]').forEach(function (el) {
      el.addEventListener("click", function (e) {
        e.preventDefault();
        showBanner();
      });
    });

    var current = getConsent();
    if (current === "all") {
      activateMarketing();
    } else if (current === "essential") {
      // schweigen
    } else {
      showBanner();
    }
  })();
</script>
