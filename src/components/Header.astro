---
import { Image } from "astro:assets";
import { city } from "../data/city";
import { features } from "../data/features";
import { categories } from "../data/categories";
import logo from "../assets/branding/logo.svg";

const navItems = categories
  .filter((c) => {
    if (c.slug === "blog") return features.blog.enabled;
    if (c.slug === "stadtteile") return features.stadtteilHotels.enabled;
    if (c.slug === "tourismus") return features.tourismus.enabled;
    if (c.slug === "leben" || c.slug === "leistungen" || c.slug === "firmen") return features.branchen.enabled;
    return true;
  })
  .map((c) => ({ href: `/thema/${c.slug}/`, label: c.name, icon: c.icon, short: c.short }));

// Events-Hub als Extra-Item ans Ende der Hauptnav anhängen.
navItems.push({ href: "/events/", label: "Events", icon: "📅", short: "Termine + Hotels für Schlossbeleuchtung, Festspiele, Weihnachtsmarkt & Co." });

const quickLinks = [
  { href: "/sehenswuerdigkeiten/", label: "Sehenswürdigkeiten" },
  { href: "/hotels/",              label: "Hotels" },
  { href: "/restaurants/",         label: "Restaurants" },
  { href: "/cafes/",               label: "Cafés" },
  { href: "/events/",              label: "Events" },
];
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-[var(--color-lavender-ash)]">
  <div class="container-page">
    <div class="flex items-center justify-between h-16 gap-4">
      <a href="/" class="flex items-center shrink-0" style="color: var(--color-accent);" aria-label={`${city.brandName} Startseite`}>
        <Image src={logo} alt={city.brandName} width={320} height={64} class="h-10 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Hauptnavigation">
        {navItems.map((item) => (
          <a href={item.href} class="px-3 py-2 text-sm font-semibold rounded-full transition-colors hover:bg-[var(--color-porcelain-mist)]" style="color: var(--color-shadow-graphite);">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2 shrink-0">
        {features.werben.enabled && (
          <a href="/werben/" class="btn-outline hidden lg:inline-flex">Werben</a>
        )}
        <button
          type="button"
          id="mobile-menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Menü öffnen"
          class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-xl border border-[var(--color-lavender-ash)] hover:bg-[var(--color-porcelain-mist)] transition-colors"
          style="color: var(--color-shadow-graphite);"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="7" x2="21" y2="7"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="17" x2="21" y2="17"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<div id="mobile-menu-backdrop" class="lg:hidden mobile-menu-backdrop" aria-hidden="true"></div>

<aside
    id="mobile-menu"
    class="lg:hidden mobile-menu-panel"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile Navigation"
    aria-hidden="true"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-[var(--color-lavender-ash)] shrink-0">
      <a href="/" class="flex items-center shrink-0" aria-label={`${city.brandName} Startseite`}>
        <Image src={logo} alt={city.brandName} width={280} height={64} class="h-8 w-auto" />
      </a>
      <button
        type="button"
        id="mobile-menu-close"
        aria-label="Menü schließen"
        class="inline-flex items-center justify-center w-10 h-10 rounded-lg hover:bg-[var(--color-porcelain-mist)] transition-colors"
        style="color: var(--color-shadow-graphite);"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Hauptnavigation mobil">
      <p class="px-4 mb-2 text-xs uppercase tracking-widest font-bold" style="color: var(--color-slate-steel);">Themen</p>
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="flex items-center gap-3 px-4 py-3 rounded-xl text-base font-semibold transition-colors hover:bg-[var(--color-porcelain-mist)]"
              style="color: var(--color-inkwell-purple);"
            >
              <span class="text-xl shrink-0" aria-hidden="true">{item.icon}</span>
              <span class="flex-1">{item.label}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color: var(--color-slate-steel);">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-6 pt-6 border-t border-[var(--color-lavender-ash)]">
        <p class="px-4 mb-3 text-xs uppercase tracking-widest font-bold" style="color: var(--color-slate-steel);">Beliebte Seiten</p>
        <div class="flex flex-wrap gap-2 px-2">
          {quickLinks.map((q) => (
            <a href={q.href} class="pill hover:border-[var(--color-accent)]">{q.label}</a>
          ))}
        </div>
      </div>

      <div class="mt-6 pt-6 border-t border-[var(--color-lavender-ash)]">
        <p class="px-4 mb-2 text-xs uppercase tracking-widest font-bold" style="color: var(--color-slate-steel);">Service</p>
        <ul class="space-y-1">
          <li><a href="/impressum/" class="block px-4 py-2.5 rounded-xl text-sm transition-colors hover:bg-[var(--color-porcelain-mist)]" style="color: var(--color-slate-steel);">Impressum</a></li>
          <li><a href="/datenschutz/" class="block px-4 py-2.5 rounded-xl text-sm transition-colors hover:bg-[var(--color-porcelain-mist)]" style="color: var(--color-slate-steel);">Datenschutz</a></li>
        </ul>
      </div>
    </nav>

    {features.werben.enabled && (
      <div class="px-5 py-4 border-t border-[var(--color-lavender-ash)] shrink-0" style="background: var(--color-porcelain-mist);">
        <a href="/werben/" class="btn-primary w-full justify-center">Werben auf {city.brandName}</a>
      </div>
    )}
  </aside>

<style>
  .mobile-menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    z-index: 60;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 220ms ease, visibility 0s linear 220ms;
  }
  .mobile-menu-backdrop.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 220ms ease, visibility 0s linear 0s;
  }
  .mobile-menu-panel {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(88vw, 380px);
    background: #ffffff;
    border-left: 1px solid var(--color-lavender-ash);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.12);
    z-index: 70;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 260ms;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .mobile-menu-panel.is-open {
    transform: translateX(0);
    visibility: visible;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 0s;
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.getElementById('mobile-menu-toggle');
    var closeBtn = document.getElementById('mobile-menu-close');
    var menu = document.getElementById('mobile-menu');
    var backdrop = document.getElementById('mobile-menu-backdrop');
    if (!toggle || !menu || !backdrop || !closeBtn) return;
    var openState = false;
    function setOpen(open) {
      openState = open;
      menu.classList.toggle('is-open', open);
      backdrop.classList.toggle('is-open', open);
      menu.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
      document.body.style.overflow = open ? 'hidden' : '';
    }
    toggle.addEventListener('click', function () { setOpen(!openState); });
    closeBtn.addEventListener('click', function () { setOpen(false); toggle.focus(); });
    backdrop.addEventListener('click', function () { setOpen(false); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && openState) { setOpen(false); toggle.focus(); }
    });
    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () { setOpen(false); });
    });
    var mq = window.matchMedia('(min-width: 1024px)');
    function handleResize(e) { if (e.matches && openState) setOpen(false); }
    if (mq.addEventListener) mq.addEventListener('change', handleResize);
    else mq.addListener(handleResize);
  })();
</script>
